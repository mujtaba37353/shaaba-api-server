# Server
PORT=3000
NODE_ENV=development

# WordPress / WooCommerce
WC_BASE_URL=http://sshaabaa.local
WC_CONSUMER_KEY=ck_your_consumer_key
WC_CONSUMER_SECRET=cs_your_consumer_secret

# WordPress Application Password (required for production to access WP Users API)
WP_ADMIN_USER=admin_username
WP_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx_xxxx_xxxx

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=30d

# WooCommerce Webhooks
WEBHOOK_SECRET=your_webhook_secret_here

# CORS
ALLOWED_ORIGINS=*

# Polling fallback interval (ms)
POLL_INTERVAL=60000
